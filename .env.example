# Optional DeepSeek — ONLY for headless thesis auto-distillation scripts.
# Cursor users: configure DeepSeek in Cursor Settings → Models (UI), NOT here.
# OpenClaw users: configure model in OpenClaw config.
#
# Uncomment the next line (remove leading #) then paste your key:
DEEPSEEK_API_KEY=sk-your-key-here

# Optional X API — leave blank for offline bundled corpus.
# X_BEARER_TOKEN=your_x_api_bearer_token_here

# SERENITY_TWITTER_SYNC_ENABLED=true
# SERENITY_SYNDICATION_FALLBACK=false

# Auto-apply distill after sync (uses DEEPSEEK_API_KEY if set, else tweet preview stubs)
# SERENITY_AUTO_DISTILL=true
